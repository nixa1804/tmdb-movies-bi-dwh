    <connection>pg_dwh</connection>
    <execute_each_row>N</execute_each_row>
    <limit>0</limit>
    <sql>SELECT DISTINCT
    release_date                                              AS full_date,
    EXTRACT(DAY FROM release_date)::INTEGER                   AS day_num,
    EXTRACT(MONTH FROM release_date)::INTEGER                 AS month_num,
    TRIM(TO_CHAR(release_date, 'Month'))                      AS month_name,
    EXTRACT(QUARTER FROM release_date)::INTEGER               AS quarter_num,
    EXTRACT(YEAR FROM release_date)::INTEGER                  AS year_num,
    (EXTRACT(YEAR FROM release_date)::INTEGER / 10 * 10)::TEXT || '-e' AS decade
FROM staging.stg_movies
WHERE release_date IS NOT NULL
ORDER BY release_date;</sql>
    <variables_active>N</variables_active>
